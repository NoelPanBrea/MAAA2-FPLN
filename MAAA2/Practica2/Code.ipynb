    "outliers = []\n",
    "outliers_labels = []\n",
    "\n",
    "for i in num_labels:\n",
    "    cluster_labels = y_train == i\n",
    "    cluster = X_train[cluster_labels]\n",
    "    medoid = np.median(cluster, axis = 0)\n",
    "    distances = np.linalg.norm((cluster - medoid), axis=1)\n",
    "    Q1 = np.percentile(distances, 25)\n",
    "    Q3 = np.percentile(distances, 75)\n",
    "    IQR = Q3 - Q1\n",
    "    lower_bound = Q1 - 1.5 * IQR\n",
    "    upper_bound = Q3 + 1.5 * IQR\n",
    "    outliers_mask = (distances < lower_bound) + (distances > upper_bound)\n",
    "    outliers.append(cluster[outliers_mask])\n",
    "    outliers_labels.append([i for x in outliers_mask if x == 1])\n",
    "plt.imshow(outliers[0][0].reshape(28, 28))"
   ]
